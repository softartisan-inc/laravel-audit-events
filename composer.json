{
    "name": "softartisan/laravel-audit-events",
    "description": "Tamper-evident audit trail for Laravel: automatic Eloquent model auditing, free-standing semantic events, an HMAC hash-chain integrity guarantee, and cold archiving for long-term compliance.",
    "keywords": [
        "softartisan",
        "laravel",
        "laravel-audit-events",
        "audit",
        "audit-trail",
        "audit-log",
        "activity-log",
        "event-sourcing",
        "compliance",
        "tamper-evident",
        "integrity"
    ],
    "homepage": "https://github.com/softartisan-inc/laravel-audit-events",
    "license": "MIT",
    "authors": [
        {
            "name": "SoftArtisan",
            "email": "henoc.djabia@softartisan.net",
            "homepage": "https://softartisan.net",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/softartisan-inc/laravel-audit-events/issues",
        "source": "https://github.com/softartisan-inc/laravel-audit-events"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "suggest": {
        "laravel/mcp": "^0.4 — Optional. Install to enable the Model Context Protocol (MCP) integration (tool, prompt, and server)."
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/mcp": "^0.4",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpro/grumphp": "^2.18",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "SoftArtisan\\LaravelAuditEvents\\": "src/",
            "SoftArtisan\\LaravelAuditEvents\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SoftArtisan\\LaravelAuditEvents\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@composer run prepare"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "test": "vendor/bin/pest",
        "test-cls": "vendor/bin/pest --colors=always",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpro/grumphp": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SoftArtisan\\LaravelAuditEvents\\LaravelAuditEventsServiceProvider"
            ],
            "aliases": {
                "LaravelAuditEvents": "SoftArtisan\\LaravelAuditEvents\\Facades\\LaravelAuditEvents"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
