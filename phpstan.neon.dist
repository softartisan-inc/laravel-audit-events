includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
        - tests/Fixtures
        - tests/TestCase.php
        - tests/Pest.php
    excludePaths:
        - src/Mcp/*
        - tests/Feature/*
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: true
    # Pest test feature files (tests/Feature) are excluded because PHPStan cannot
    # properly analyze Pest closures bound via uses() without a dedicated Pest
    # PHPStan extension. Test correctness is guaranteed by the Pest test suite itself.
